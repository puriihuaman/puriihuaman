---
import {getCollection} from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const [serviceEntry] = await getCollection("service");
const {Content} = await serviceEntry.render();

const title = "Servicios | Puriihuaman";
const description = "Servicios de desarrollo back-end ofrecidos por Puriihuaman — API REST, Java, Spring Boot y asesoría técnica.";
---

<BaseLayout title={title} description={description}>
	<section class="container services">
		<Content />
	</section>
</BaseLayout>
